    "cutting_system.cutting_line.instruction": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スペースキー/画面タッチ\nで切断"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按空格键/触摸屏幕\n进行切割"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press Space/Touch Screen\nto Cut"
          }
        }
      }
    },
    "cutting_system.cutting_progress": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "切断進度: %1$@/%2$@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "切割进度: %1$@/%2$@"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cutting Progress: %1$@/%2$@"
          }
        }
      }
    },
    "cutting_system.failure_message": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "❌ 切断失敗\n\nサンプルは破壊されました\n切断するサンプルを再選択してください"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "❌ 切割失败\n\n样本已被销毁\n请重新选择样本进行切割"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "❌ Cutting Failed\n\nSample has been destroyed\nPlease select a new sample for cutting"
          }
        }
      }
    },
    "cutting_system.initialization_failed": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "切断システム初期化失敗"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "切割系统初始化失败"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cutting system initialization failed"
          }
        }
      }
    },
    "cutting_system.instruction.cutting_in_progress": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "切断中: %1$@\n\n移動する切断線を見て\nスペースキー/画面タッチで切断\n\n⚠️ 切断失敗でサンプルは破壊される"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在切割: %1$@\n\n观察移动的切割线\n按空格键/触摸屏幕进行切割\n\n⚠️ 切割失败会销毁样本"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cutting: %1$@\n\nWatch the moving cutting line\nPress Space/Touch screen to cut\n\n⚠️ Cutting failure will destroy the sample"
          }
        }
      }
    },
    "cutting_system.instruction.drag_sample": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "多層地質サンプルを\n左側からここにドラッグ\n\nサンプル切断操作を開始\n\n対応サンプルタイプ:\n• 多層掘削サンプル\n• 地質探査サンプル"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将多层地质样本\n从左侧拖拽到此处\n\n开始样本切割操作\n\n支持的样本类型:\n• 多层钻孔样本\n• 地质探查样本"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag multi-layer geological samples\nfrom the left to here\n\nStart sample cutting operation\n\nSupported sample types:\n• Multi-layer drill samples\n• Geological exploration samples"
          }
        }
      }
    },
    "cutting_system.instruction.multi_layer_required": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "多層サンプルのみ切断可能"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只能切割多层样本"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only multi-layer samples can be cut"
          }
        }
      }
    },
    "cutting_system.success_message": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "✅ 切断成功！\n\n単層サンプルがバックパックに追加されました\n他のサンプルの切断を続けることができます"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "✅ 切割成功！\n\n单层样本已添加到背包\n可以继续切割其他样本"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "✅ Cutting Successful!\n\nSingle-layer samples added to backpack\nYou can continue cutting other samples"
          }
        }
      }
    },
