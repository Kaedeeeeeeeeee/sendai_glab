          "stringUnit": {
            "state": "translated",
            "value": "この地層で発見された三葉虫化石、古生代海洋生物の代表。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在该地层中发现的三叶虫化石，是古生代海洋生物的代表。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Trilobite fossils discovered in this formation, representatives of Paleozoic marine life."
          }
        }
      }
    },
    "geology.detection.failed": {
      "extractionState": "manual",
      "localizations": {
