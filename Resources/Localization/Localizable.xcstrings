    "mineral.description.amphibole": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "色は主に黒色、深緑色または深褐色、ガラス光沢。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "颜色多为黑色、深绿色或深褐色，玻璃光泽。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Colors are mostly black, dark green or dark brown, with vitreous luster."
          }
        }
      }
    },
    "mineral.description.biotite": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "色は黒色から褐色または黄色、ガラス光沢から真珠光沢、白色条痕；結晶形は通常偽六角板状。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "颜色黑色至褐色或黄色，具玻璃至珍珠光泽，条痕白色，晶形常呈假六方片状。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Colors black to brown or yellow, vitreous to pearly luster, white streak; crystal form commonly pseudo-hexagonal tabular."
          }
        }
      }
    },
    "mineral.description.carbonaceous_matter": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "碳质物质是含碳的有机或无机化合物，通常呈黑色或深褐色，具有特征的碳质光泽。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Carbonaceous matter consists of carbon-bearing organic or inorganic compounds; usually black or dark brown in color with characteristic carbonaceous luster."
          }
        }
      }
    },
    "mineral.description.clay_minerals": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "主に含水アルミニウムケイ酸塩の細粒鉱物集合体、軟質、湿潤時に可塑性；色は主に白色、灰色または淡褐色、土状光沢、通常土状または粉末状集合体として産出。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "以含水铝硅酸盐为主的细粒矿物集合体，质地柔软，湿润时具有可塑性；颜色多为白色、灰色或浅褐色，光泽土状，常呈土状或粉末状集合体。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fine-grained mineral aggregates mainly of hydrous aluminum silicates, soft texture, plastic when moist; colors mostly white, gray or light brown, earthy luster, commonly occur as earthy or powdery aggregates."
          }
        }
      }
    },
    "mineral.description.feldspar": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "色はピンク、白、灰、褐または青色；ガラス光沢、白色条痕。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "颜色可为粉红、白、灰、褐或蓝色，玻璃光泽，条痕白色。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Colors can be pink, white, gray, brown or blue; vitreous luster, white streak."
          }
        }
      }
    },
    "mineral.description.garnet": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "色はほぼ全色域をカバー、一般的には赤色；結晶は菱形十二面体または立方体、貝殻状から不平坦な断口、ガラス光沢または樹脂光沢、白色条痕。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "颜色几乎涵盖所有色谱，常见为红色；晶体为菱形十二面体或立方体，断口贝壳状至不平，光泽玻璃或树脂光泽，条痕白色。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Colors cover almost entire spectrum, commonly red; crystals are rhombic dodecahedra or cubes, conchoidal to uneven fracture, vitreous or resinous luster, white streak."
          }
        }
      }
    },
    "mineral.description.heavy_minerals": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "重鉱物とは高密度鉱物（ジルコン、チタン磁鉄鉱、ザクロ石など）の集合体を指し、砂中に一般的に見られる；通常暗色、細粒、光沢あり。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "重矿物指密度较大的矿物（如锆石、钛磁铁矿、石榴石等）的集合体，常出现在砂中，颜色通常较深，粒度细小，具光泽。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Heavy minerals refer to aggregates of high-density minerals (such as zircon, titanomagnetite, garnet, etc.), commonly found in sands; usually dark colors, fine grain size, lustrous."
          }
        }
      }
    },
    "mineral.description.hypersthene": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "色は灰色、褐色または緑色；不平坦な断口、ガラス光沢から真珠光沢、灰白色または緑灰色条痕、表面に銅赤色金属光沢。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "颜色灰色、褐色或绿色，断口不平，光泽玻璃至珍珠，条痕灰白或绿灰，表面有铜红色金属光泽。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Colors gray, brown or green; uneven fracture, vitreous to pearly luster, grayish-white or greenish-gray streak, surface with coppery-red metallic luster."
          }
        }
      }
    },
    "mineral.description.illite_alteration_product": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "颜色灰白、银白或绿灰色，集合体呈云母状薄片，光泽珍珠至土状；条痕白色；半透明。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Colors grayish-white, silvery-white or greenish-gray; aggregates occur as mica-like thin sheets, pearly to earthy luster; white streak; translucent."
          }
        }
      }
    },
    "mineral.description.magnetite_detailed": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通常黒色または灰色で褐色調、金属光沢；不平坦な断口、黒色条痕。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "颜色通常黑色或灰色带棕色调，具金属光泽；断口不平，条痕黑色。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Usually black or gray with brownish tones, metallic luster; uneven fracture, black streak."
          }
        }
      }
    },
    "mineral.description.magnetite_simple": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通常黒色または灰色で褐色調、金属光沢。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "颜色通常黑色或灰色带棕色调，具金属光泽。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Usually black or gray with brownish tones, metallic luster."
          }
        }
      }
    },
    "mineral.description.olivine": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "色はオリーブ緑色から黄褐色、ガラス光沢、白色条痕；鉄含有量の高い試料は表面が赤色に酸化する。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "颜色多为橄榄绿至黄褐色，玻璃光泽，条痕白色，铁含量高的样品表面会氧化呈红色。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Colors range from olive green to yellowish brown, vitreous luster, white streak; high-iron samples may oxidize to red on surface."
          }
        }
      }
    },
    "mineral.description.orthopyroxene": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "颜色灰色、褐色或绿色，光泽玻璃至珍珠，条痕灰白或绿灰，表面有铜红色金属光泽。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Colors gray, brown or green; vitreous to pearly luster, grayish-white or greenish-gray streak, surface with coppery-red metallic luster."
          }
        }
      }
    },
    "mineral.description.plagioclase": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通常白色または灰色、時に淡い青みや淡い緑みを帯びる；ガラス光沢。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通常呈白色或灰色，有时带淡蓝或淡绿；玻璃光泽。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Usually white or gray, sometimes with pale blue or pale green tints; vitreous luster."
          }
        }
      }
    },
    "mineral.description.pumice": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "浮石是一种浅色的多孔火山岩，含大量气孔，质地轻可浮于水面，通常为白色或淡灰色，是喷出岩。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pumice is a light-colored, porous volcanic rock containing numerous vesicles; light enough to float on water, usually white or light gray; an extrusive igneous rock."
          }
        }
      }
    },
    "mineral.description.pyroxene": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "深緑色、褐色から黒色の暗色、柱状結晶形、ガラス光沢から暗色光沢。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "呈深绿色、褐色至黑色等深色，柱状晶形，光泽玻璃至暗淡。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dark green, brown to black colors, prismatic crystal form, vitreous to dull luster."
          }
        }
      }
    },
    "mineral.description.quartz": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "無色、ピンク、オレンジ、白、緑、黄、青、紫または深褐色など多様な色；貝殻状断口、ガラス光沢、白色条痕。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "呈无色、粉色、橙色、白色、绿色、黄色、蓝色、紫色或深褐色等多种颜色，断口贝壳状，玻璃光泽，条痕白色。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Occurs in colorless, pink, orange, white, green, yellow, blue, purple or dark brown varieties; conchoidal fracture, vitreous luster, white streak."
          }
        }
      }
    },
    "mineral.description.volcanic_ash": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "火山灰是火山喷发时产生的细粒火山碎屑物质，颗粒细小，通常为灰色至深灰色。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Volcanic ash consists of fine-grained volcanic pyroclastic material produced during volcanic eruptions; fine particles, usually gray to dark gray in color."
          }
        }
      }
    },
    "mineral.description.volcanic_glass": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通常黒色、緑色または褐色もあり；典型的な貝殻状断口、滑らかなガラス状質感、ガラス光沢。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通常黑色，也有绿色或褐色，断口呈典型贝壳状，质地光滑玻璃状，玻璃光泽。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Usually black, also green or brown; typical conchoidal fracture, smooth glassy texture, vitreous luster."
          }
        }
      }
    },
    "mineral.description.zircon_long": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "色は深褐、黒、灰、淡褐、褐赤、オレンジ、ピンクなど多様、無色条痕、樹脂光沢からダイヤモンド光沢；貝殻状から不平坦な断口、結晶は通常短柱状または水磨円粒。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "颜色深褐、黑、灰、浅褐、褐红、橙、粉红等多种，条痕无色，光泽油脂至金刚光泽，断口贝壳状至不平，晶体常为短柱状或水磨圆粒。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Colors vary including dark brown, black, gray, light brown, reddish brown, orange, pink; colorless streak, resinous to adamantine luster; conchoidal to uneven fracture, crystals commonly short prismatic or water-worn grains."
          }
        }
      }
    },
    "mineral.description.zircon_short": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "色は深褐、黒、灰、淡褐、褐赤、オレンジ、ピンクなど多様、無色条痕、樹脂光沢からダイヤモンド光沢；貝殻状から不平坦な断口、結晶は通常短柱状または水磨円粒。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "颜色深褐、黑、灰、浅褐、褐红、橙、粉红等多种，条痕无色，光泽油脂至金刚光泽。断口贝壳状至不平，晶体常为短柱状或水磨圆粒。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Colors vary including dark brown, black, gray, light brown, reddish brown, orange, pink; colorless streak, resinous to adamantine luster; conchoidal to uneven fracture, crystals commonly short prismatic or water-worn grains."
          }
        }
      }
    },
