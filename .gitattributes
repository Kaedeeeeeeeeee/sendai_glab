# ==========================================================================
# SDG-Lab .gitattributes
#
# Git LFS patterns + cross-platform line-ending normalization.
# Committed to the repo so every fresh clone / fork inherits the same rules
# (GitHub Docs: Configuring Git Large File Storage).
#
# P0-T7 notes:
#   * main agent will run `git lfs install` once before first commit.
#   * `git check-attr filter <path>` must return "lfs" for covered patterns.
#   * PNG / JPG are NOT blanket-tracked — UI icons are small and go through
#     regular Git. Large textures should be committed under
#     `Resources/Textures/**` once that path exists and an explicit LFS rule
#     is added here.
# ==========================================================================

# ---------- 3D assets ----------
*.usdz   filter=lfs diff=lfs merge=lfs -text
*.usda   filter=lfs diff=lfs merge=lfs -text
*.usdc   filter=lfs diff=lfs merge=lfs -text
*.glb    filter=lfs diff=lfs merge=lfs -text
*.gltf   filter=lfs diff=lfs merge=lfs -text
*.fbx    filter=lfs diff=lfs merge=lfs -text
*.obj    filter=lfs diff=lfs merge=lfs -text

# ---------- Images (raw / large-format) ----------
*.heic   filter=lfs diff=lfs merge=lfs -text
*.tiff   filter=lfs diff=lfs merge=lfs -text
*.tif    filter=lfs diff=lfs merge=lfs -text

# ---------- Audio ----------
*.wav    filter=lfs diff=lfs merge=lfs -text
*.aiff   filter=lfs diff=lfs merge=lfs -text
*.flac   filter=lfs diff=lfs merge=lfs -text
*.mp3    filter=lfs diff=lfs merge=lfs -text
*.m4a    filter=lfs diff=lfs merge=lfs -text
*.caf    filter=lfs diff=lfs merge=lfs -text

# ---------- Large PNG / JPG opt-in ----------
# Default PNG/JPG stay in regular Git (UI icons, small screenshots).
# When Textures/ appears, uncomment the matching line below:
# Resources/Textures/**/*.png  filter=lfs diff=lfs merge=lfs -text
# Resources/Textures/**/*.jpg  filter=lfs diff=lfs merge=lfs -text
# Resources/Geology/ThinSections/**/*.jpg filter=lfs diff=lfs merge=lfs -text

# ---------- Text: enforce LF everywhere ----------
*.swift     text eol=lf
*.md        text eol=lf
*.json      text eol=lf
*.xcstrings text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.sh        text eol=lf
*.py        text eol=lf
*.toml      text eol=lf
*.cfg       text eol=lf

# ---------- Xcode project file ----------
# project.pbxproj is (re)generated by xcodegen from project.yml
# (see AGENTS.md §7.2). Keep it committed but prefer union merge to reduce
# conflicts when multiple branches regenerate it.
*.pbxproj merge=union
