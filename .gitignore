# CocoaPods (if ever used)
Pods/
*.xcworkspace

# Carthage (if ever used)
Carthage/Build/

# Secrets / credentials
*.env
*.env.*
!.env.example
secrets/
*.p8
*.p12
*.cer
*.mobileprovision

# Personal signing config — each contributor keeps their own Team ID
# locally. See LocalSigning.xcconfig.example for setup.
LocalSigning.xcconfig

# API keys config (never commit)
Tools/meshy-pipeline/.meshy-api-key
Tools/*/config.local.json

# Heavy binary intermediates (use Git LFS for committed binaries)
Tools/*/intermediate/
Tools/*/output/
Tools/*/cache/

# Large raw assets (should be in LFS or external storage)
RawAssets/
*.gml
*.glb
# Exception: processed GLB under Resources/ IS committed via Git LFS
# (see .gitattributes). USDZ is the long-term target format once
# Reality Converter is in the pipeline.
!Resources/**/*.glb
# NOTE: processed USDZ under Resources/ IS committed (with LFS)

# Python (for Tools/)
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/

# Node (if any web tooling)
node_modules/

# Logs
*.log
logs/

